blueprint:
  name: Enforce Light On During Time Window, Off After
  description: Keeps a light entity on during a time window, then turns it off after the window. Useful for light-presented switches such as heated towel rails.
  domain: automation

  input:
    target_light:
      name: Target light
      selector:
        entity:
          domain: light

    start_time:
      name: Start time
      default: "11:00:00"
      selector:
        time: {}

    end_time:
      name: End time
      default: "14:00:00"
      selector:
        time: {}

    check_interval_minutes:
      name: Watchdog interval minutes
      default: "/1"
      selector:
        text: {}

mode: single

trigger:
  - platform: time
    at: !input start_time

  - platform: time
    at: !input end_time

  - platform: homeassistant
    event: start

  - platform: time_pattern
    minutes: !input check_interval_minutes

variables:
  target_light: !input target_light
  start_time: !input start_time
  end_time: !input end_time
  now_time: "{{ now().strftime('%H:%M:%S') }}"
  in_window: "{{ start_time <= now_time < end_time }}"
  after_window: "{{ now_time >= end_time }}"

action:
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ in_window }}"
          - condition: template
            value_template: "{{ is_state(target_light, 'off') }}"
        sequence:
          - service: light.turn_on
            target:
              entity_id: "{{ target_light }}"

      - conditions:
          - condition: template
            value_template: "{{ after_window }}"
          - condition: template
            value_template: "{{ is_state(target_light, 'on') }}"
        sequence:
          - service: light.turn_off
            target:
              entity_id: "{{ target_light }}"
