blueprint:
  name: Light Sync - Master with Slaves (2-way/3-way/n-way)
  description: >
    Mirrors on/off state between a master light and one or more slave lights.
    Slave change -> master set to match.
    Master change -> slaves set to match (LED sync).
    Uses restart mode + debounce for fast taps / Zigbee lag.
  domain: automation

  input:
    master_light:
      name: Master light (source of truth)
      selector:
        entity:
          domain: light

    slave_lights:
      name: Slave lights (one or more)
      selector:
        entity:
          domain: light
          multiple: true

    debounce_ms:
      name: Debounce (milliseconds)
      default: 150
      selector:
        number:
          min: 0
          max: 1000
          unit_of_measurement: ms
          step: 10
          mode: slider

mode: restart

trigger:
  - platform: state
    entity_id: !input master_light
    to: ["on", "off"]
    id: master

  - platform: state
    entity_id: !input slave_lights
    to: ["on", "off"]
    id: slave

action:
  - delay:
      milliseconds: !input debounce_ms

  - variables:
      desired: "{{ states(trigger.entity_id) }}"

  - choose:
      - conditions:
          - condition: trigger
            id: slave
        sequence:
          - service: "light.turn_{{ desired }}"
            target:
              entity_id: !input master_light

      - conditions:
          - condition: trigger
            id: master
        sequence:
          - service: "light.turn_{{ desired }}"
            target:
              entity_id: !input slave_lights
