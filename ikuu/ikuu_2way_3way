blueprint:
  name: Stable Multi-Way Light Sync (2-way / 3-way / n-way)
  description: >
    Synchronises multiple light entities so they behave like a true multi-way circuit.
    - Only reacts to on/off transitions
    - Only updates lights that differ
    - Uses small debounce delay to avoid race conditions
    Designed for Zigbee relay-style switches.

  domain: automation

  input:
    lights:
      name: Lights to sync
      description: Select all light entities that should mirror each other.
      selector:
        entity:
          domain: light
          multiple: true

    debounce_ms:
      name: Debounce delay (milliseconds)
      description: Small delay to allow Zigbee state to settle (typically 30–100ms).
      default: 50
      selector:
        number:
          min: 0
          max: 500
          step: 10
          unit_of_measurement: ms
          mode: slider

mode: restart

trigger:
  - platform: state
    entity_id: !input lights
    to:
      - "on"
      - "off"

action:
  - delay:
      milliseconds: !input debounce_ms

  - variables:
      desired: "{{ states(trigger.entity_id) }}"
      all_lights: !input lights

  - repeat:
      for_each: "{{ all_lights }}"
      sequence:
        - condition: template
          value_template: >
            {{ repeat.item != trigger.entity_id and
               states(repeat.item) != desired }}
        - service: "light.turn_{{ desired }}"
          target:
            entity_id: "{{ repeat.item }}"
